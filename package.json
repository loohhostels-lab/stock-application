{
  "name": "stock_management",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "drizzle-kit": "^1.0.0-rc.4",
    "prettier": "^3.7.4",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "add": "^2.0.6",
    "bun": "^1.3.14",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "mysql2": "^3.22.5"
  }
}